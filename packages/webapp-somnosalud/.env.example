# SomnoSalud webapp — environment variables
# Copiar a .env.local y completar los valores reales (NUNCA commitear .env.local).

# ─── Site URL (Sprint 3 hotfix — magic link emailRedirectTo) ────────────────
# Override explicito de la URL base del sitio. Si esta seteado, gana sobre
# VERCEL_PROJECT_PRODUCTION_URL / VERCEL_URL / header origin. Usar cuando
# se quiere forzar un dominio custom (ej. https://somnosalud.com.ar) o cuando
# Vercel auto-deteccion da una URL distinta a la que querras en el email.
#
# Dev local: dejar vacio, el helper usa header origin (http://localhost:3000).
# Vercel prod: dejar vacio, el helper usa VERCEL_PROJECT_PRODUCTION_URL auto.
# Dominio custom: setear `https://somnosalud.com.ar` cuando lo tengas.
NEXT_PUBLIC_SITE_URL=

# ─── Sentry (Sprint 14 — instalado idle, activable post-Vercel deploy) ──────
# DSN del project sentry.io. Mientras este vacio, el SDK NO envia eventos.
NEXT_PUBLIC_SENTRY_DSN=

# Org slug + project slug en sentry.io (necesarios para source maps upload).
SENTRY_ORG=
SENTRY_PROJECT=

# Auth token para CI builds (source map upload). Generar en sentry.io > Settings > Auth Tokens.
SENTRY_AUTH_TOKEN=

# ─── Resend (Sprint 14 — wrapper instalado idle, emails reales Sprint 9+) ──
# API key del workspace Resend. Mientras este vacio, getResendClient() retorna null.
RESEND_API_KEY=

# From address verificado en Resend (requiere DNS records del dominio).
RESEND_FROM_EMAIL=

# ─── Supabase (Sprint 2.B + 9.A) ───────────────────────────────────────────
# Project ref + URL del project somnosalud-platform (Org Pampa Labs, sa-east-1).
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_PROJECT_REF=

# Keys convencion 2025+: sb_publishable_* (browser) + sb_secret_* (server only).
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=

# Access token del Org Pampa Labs — solo para MCP supabase-somnosalud, NO
# usado por la app en runtime.
SUPABASE_ACCESS_TOKEN=
