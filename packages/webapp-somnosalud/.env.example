# SomnoSalud webapp — environment variables
# Copiar a .env.local y completar los valores reales (NUNCA commitear .env.local).

# ─── Sentry (Sprint 14 — instalado idle, activable post-Vercel deploy) ──────
# DSN del project sentry.io. Mientras este vacio, el SDK NO envia eventos.
NEXT_PUBLIC_SENTRY_DSN=

# Org slug + project slug en sentry.io (necesarios para source maps upload).
SENTRY_ORG=
SENTRY_PROJECT=

# Auth token para CI builds (source map upload). Generar en sentry.io > Settings > Auth Tokens.
SENTRY_AUTH_TOKEN=

# ─── Resend (Sprint 14 — wrapper instalado idle, emails reales Sprint 9+) ──
# API key del workspace Resend. Mientras este vacio, getResendClient() retorna null.
RESEND_API_KEY=

# From address verificado en Resend (requiere DNS records del dominio).
RESEND_FROM_EMAIL=

# ─── Supabase (Sprint 2.B+9 — pendiente) ──────────────────────────────────
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_KEY=
