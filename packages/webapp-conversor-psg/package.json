{
  "name": "@somnosalud/webapp-conversor-psg",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Frontend Vite + React + pdf.js + JSZip — utility client-side para parsear PDFs polisomnograficos. Consume @somnosalud/psg-parser (7 parsers + computeHypoxicScore Azarbarzin 2019). Legacy v0 archivado en legacy-v0/_archived/ post Sprint 19.C — cierre DEBT-conversor-psg-migration-roadmap.",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit && echo 'Types OK'",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@somnosalud/psg-parser": "workspace:*",
    "jszip": "^3.10.1",
    "pdfjs-dist": "^4.10.38",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "^5.4.0",
    "vite": "^5.4.11",
    "vitest": "^2.0.0"
  },
  "keywords": [
    "vite",
    "react",
    "pdf",
    "psg",
    "polisomnografia",
    "client-side",
    "jszip"
  ],
  "author": "SomnoSalud Team",
  "license": "PROPRIETARY"
}
